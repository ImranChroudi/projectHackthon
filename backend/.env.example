# Serveur
PORT=5000
NODE_ENV=development

# Base de données
MONGODB_URI=mongodb://127.0.0.1:27017/attendance

# URL publique du frontend (encodée dans le QR ; utilisez l'IP du PC sur le WiFi
# du centre pour un scan depuis le téléphone, ex. http://192.168.1.20:5173)
APP_URL=http://localhost:5173

# Authentification
JWT_SECRET=changez-moi-en-production
JWT_EXPIRES_IN=12h

# Secret de signature des tokens QR (HMAC)
QR_SECRET=changez-moi-aussi-en-production

# Règles métier
QR_ROTATION_SECONDS=12          # le QR tourne toutes les N secondes
SESSION_SCAN_WINDOW_MINUTES=15  # fenêtre de scan / règle des 15 minutes
RETARD_GRACE_MINUTES=5          # au-delà -> marqué "retard"
SEUIL_PROCHE=8                  # alerte stagiaire à l'approche du seuil
LIMITE_STRICTE=10               # notifie les admins immédiatement

# WiFi du centre (liste d'autorisation IP/CIDR, séparée par des virgules)
CAMPUS_CIDRS=*127.0.0.1/32,::1/128,192.168.0.0/16,10.0.0.0/8

# Job planifié (expression cron) - toutes les minutes par défaut
AUTO_ABSENCE_CRON=* * * * *

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# Admin initial (script de seed)
SEED_ADMIN_EMAIL=admin@centre.ma
SEED_ADMIN_PASSWORD=Admin123!
